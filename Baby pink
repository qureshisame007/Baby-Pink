           onerror="this.src='data:image/svg+xml,%3Csvg xmlns=%27http://www.w3.org/2000/svg%27 width=%2752%27 height=%2752%27%3E%3Crect width=%2752%27 height=%2752%27 fill=%27%23fde8ef%27/%3E%3Ctext x=%2726%27 y=%2732%27 text-anchor=%27middle%27 font-size=%2720%27%3E🌸%3C/text%3E%3C/svg%3E'" />
      <div class="cart-item-info">
        <div class="cart-item-name">${item.name}</div>
        <div class="cart-item-price">₹${item.price} each</div>
        <div class="cart-item-subtotal">Subtotal: ₹${item.price * item.qty}</div>
      </div>
      <div class="qty-controls">
        <button class="qty-btn" onclick="changeQty(${item.id}, -1)">−</button>
        <span class="qty-num">${item.qty}</span>
        <button class="qty-btn" onclick="changeQty(${item.id}, 1)">+</button>
      </div>
      <button class="remove-btn" onclick="removeItem(${item.id})" title="Remove">✕</button>
    </div>
  `).join('');

  footer.innerHTML = `
    <div class="total-row">
      <span class="total-label">Grand Total</span>
      <span class="total-amount">₹${getTotal()}</span>
    </div>
    <button class="checkout-btn" onclick="goToCheckout()">
      Proceed to Order →
    </button>`;
}

function goToCheckout() {
  currentView = 'checkout';
  renderCartBody();
}

/* ════════════════════════════════════════════
   CHECKOUT FORM
════════════════════════════════════════════ */
function renderCheckoutForm(body, footer, title) {
  title.textContent = '📦 Place Order';

  const orderLines = cart.map(i =>
    `${i.name} x${i.qty} = Rs.${i.price * i.qty}`
  ).join('\n');
  const orderSummary = `ORDER SUMMARY\n${'-'.repeat(30)}\n${orderLines}\n${'-'.repeat(30)}\nGrand Total: Rs.${getTotal()}\n${'-'.repeat(30)}\nShop: Baby Pink | 8602675154`;

  body.innerHTML = `
    <button class="back-link" onclick="currentView='cart'; renderCartBody()">
      ← Back to cart
    </button>

    <div class="form-section">
      <h3>Your Delivery Details</h3>

      <form id="orderForm"
            action="https://formspree.io/f/YOUR_FORM_ID_HERE"
            method="POST"
            onsubmit="handleSubmit(event)">

        <!-- Hidden fields carry full order data -->
        <input type="hidden" name="_subject" value="New Order from Baby Pink Website 🛍️" />
        <input type="hidden" name="order_summary" id="hiddenSummary" value="${orderSummary.replace(/"/g, '&quot;')}" />
        <input type="hidden" name="grand_total" value="Rs.${getTotal()}" />

        <div class="form-group">
          <label>Your Name *</label>
          <input type="text" name="customer_name" placeholder="e.g. Priya Sharma" required />
        </div>
        <div class="form-group">
          <label>Phone Number *</label>
          <input type="tel" name="customer_phone" placeholder="e.g. 9876543210" required pattern="[0-9]{10}" />
        </div>
        <div class="form-group">
          <label>Delivery Address *</label>
          <input type="text" name="delivery_address" placeholder="House no., Street, Village/Town, Pincode" required />
        </div>
        <div class="form-group">
          <label>Special Instructions (optional)</label>
          <textarea name="special_instructions" placeholder="Any notes for the shopkeeper..."></textarea>
        </div>

        <!-- Readable cart summary in form -->
        <div class="form-group">
          <label>Your Order</label>
          <textarea name="cart_items" readonly style="font-family:monospace;font-size:0.7rem;background:#fde8ef;color:#2a1a1e;">${orderSummary}</textarea>
        </div>

        <button type="submit" class="place-order-btn" id="placeOrderBtn">
          🌸 Confirm & Place Order
        </button>
      </form>

      <p style="font-size:0.68rem;color:#8a6570;text-align:center;margin-top:0.8rem;line-height:1.6;">
        ⚠️ <em>This is not an online payment. Baby Pink will confirm your order via WhatsApp.</em>
      </p>
    </div>`;

  footer.innerHTML = '';
}

/* ════════════════════════════════════════════
   FORM SUBMIT (Formspree)
════════════════════════════════════════════ */
async function handleSubmit(e) {
  e.preventDefault();
  const form = e.target;
  const btn  = document.getElementById('placeOrderBtn');

  btn.disabled = true;
  btn.textContent = 'Sending…';

  const data = new FormData(form);

  try {
    const res = await fetch(form.action, {
      method: 'POST',
      body: data,
      headers: { Accept: 'application/json' }
    });

    if (res.ok) {
      cart = [];
      saveCart();
      updateBadges();
      currentView = 'success';
      renderCartBody();
      renderProducts(document.querySelector('.pill.active').dataset.cat);
    } else {
      const err = await res.json();
      if (err.errors && err.errors[0].message.includes('form')) {
        // Formspree not configured — demo mode
        showDemoSuccess();
      } else {
        btn.disabled = false;
        btn.textContent = '🌸 Confirm & Place Order';
        showToast('Something went wrong. Please try again.');
      }
    }
  } catch {
    // Network error or Formspree not yet configured
    showDemoSuccess();
  }
}

function showDemoSuccess() {
  // Fallback: open WhatsApp with order details instead
  const lines = cart.map(i => `• ${i.name} x${i.qty} = ₹${i.price * i.qty}`).join('%0a');
  const msg = encodeURIComponent(
    `🌸 New Order from Baby Pink Website\n\n${cart.map(i=>`• ${i.name} x${i.qty} = ₹${i.price*i.qty}`).join('\n')}\n\nGrand Total: ₹${getTotal()}`
  );
  window.open(`https://wa.me/918602675154?text=${msg}`, '_blank');

  cart = [];
  saveCart();
  updateBadges();
  currentView = 'success';
  renderCartBody();
  renderProducts(document.querySelector('.pill.active').dataset.cat);
}

/* ════════════════════════════════════════════
   TOAST
════════════════════════════════════════════ */
let toastTimer;
function showToast(msg) {
  const t = document.getElementById('toast');
  t.textContent = msg;
  t.classList.add('show');
  clearTimeout(toastTimer);
  toastTimer = setTimeout(() => t.classList.remove('show'), 2200);
}

/* ════════════════════════════════════════════
   INIT
════════════════════════════════════════════ */
renderProducts();
updateBadges();
</script>
</body>
</html>
