<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Baby Pink – Princess Glow</title>
  <meta name="description" content="Baby Pink – Princess Glow. Shop skin care, makeup, hair care, bath & body, and nail care products." />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400&family=DM+Sans:ital,wght@0,300;0,400;0,500;1,300&display=swap" rel="stylesheet" />
  <style>
    /* ── RESET & BASE ─────────────────────────────────────── */
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; }
    body {
      font-family: 'DM Sans', sans-serif;
      background: #fff8f9;
      color: #2a1a1e;
      min-height: 100vh;
      overflow-x: hidden;
    }

    /* ── CSS VARIABLES ───────────────────────────────────── */
    :root {
      --pink:        #f4a9be;
      --pink-deep:   #e07090;
      --pink-soft:   #fde8ef;
      --rose:        #c9536e;
      --cream:       #fff8f9;
      --gold:        #c9a078;
      --gold-light:  #f0dcc8;
      --text:        #2a1a1e;
      --text-muted:  #8a6570;
      --white:       #ffffff;
      --shadow:      0 4px 24px rgba(200,80,110,0.10);
      --shadow-lg:   0 12px 48px rgba(200,80,110,0.18);
      --radius:      18px;
      --radius-sm:   10px;
      --transition:  0.3s cubic-bezier(.4,0,.2,1);
    }

    /* ── HEADER ──────────────────────────────────────────── */
    header {
      background: linear-gradient(135deg, #fde8ef 0%, #fff0f5 50%, #fde8ef 100%);
      border-bottom: 1px solid #f4c8d8;
      position: sticky;
      top: 0;
      z-index: 100;
      padding: 0 1rem;
    }
    .header-inner {
      max-width: 900px;
      margin: 0 auto;
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 0.75rem 0;
    }
    .brand {
      display: flex;
      flex-direction: column;
      line-height: 1;
    }
    .brand-name {
      font-family: 'Cormorant Garamond', serif;
      font-size: clamp(1.5rem, 4vw, 2rem);
      font-weight: 600;
      color: var(--rose);
      letter-spacing: 0.04em;
    }
    .brand-name span { color: var(--gold); }
    .brand-tagline {
      font-size: 0.65rem;
      font-weight: 300;
      letter-spacing: 0.25em;
      text-transform: uppercase;
      color: var(--text-muted);
      margin-top: 2px;
    }
    /* Cart button in header */
    .header-cart-btn {
      position: relative;
      background: var(--rose);
      color: #fff;
      border: none;
      border-radius: 50px;
      padding: 0.5rem 1.1rem;
      font-family: 'DM Sans', sans-serif;
      font-size: 0.8rem;
      font-weight: 500;
      cursor: pointer;
      display: flex;
      align-items: center;
      gap: 6px;
      transition: var(--transition);
      box-shadow: 0 4px 14px rgba(200,80,110,0.25);
    }
    .header-cart-btn:hover { background: var(--pink-deep); transform: translateY(-1px); }
    .cart-badge {
      background: #fff;
      color: var(--rose);
      border-radius: 50%;
      width: 18px;
      height: 18px;
      font-size: 0.65rem;
      font-weight: 700;
      display: flex;
      align-items: center;
      justify-content: center;
      flex-shrink: 0;
    }

    /* ── HERO STRIP ──────────────────────────────────────── */
    .hero-strip {
      background: linear-gradient(to right, #fce4ec, #fff0f5, #f8bbd0, #fce4ec);
      background-size: 300% 100%;
      animation: shimmer 6s ease-in-out infinite;
      text-align: center;
      padding: 2.2rem 1rem 1.8rem;
    }
    @keyframes shimmer {
      0%,100% { background-position: 0% 50%; }
      50%      { background-position: 100% 50%; }
    }
    .hero-title {
      font-family: 'Cormorant Garamond', serif;
      font-size: clamp(2rem, 6vw, 3.4rem);
      font-weight: 300;
      font-style: italic;
      color: var(--rose);
      line-height: 1.1;
    }
    .hero-sub {
      font-size: 0.8rem;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: var(--text-muted);
      margin-top: 0.4rem;
    }
    .hero-divider {
      width: 60px;
      height: 1.5px;
      background: var(--gold);
      margin: 0.8rem auto 0;
      border-radius: 2px;
    }

    /* ── CATEGORY FILTER ─────────────────────────────────── */
    .filter-section {
      max-width: 900px;
      margin: 1.8rem auto 0;
      padding: 0 1rem;
    }
    .filter-label {
      font-size: 0.65rem;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--text-muted);
      margin-bottom: 0.6rem;
    }
    .filter-pills {
      display: flex;
      gap: 0.5rem;
      flex-wrap: wrap;
    }
    .pill {
      padding: 0.4rem 1rem;
      border-radius: 50px;
      border: 1.5px solid var(--pink);
      background: transparent;
      color: var(--rose);
      font-family: 'DM Sans', sans-serif;
      font-size: 0.78rem;
      font-weight: 400;
      cursor: pointer;
      transition: var(--transition);
      white-space: nowrap;
    }
    .pill:hover { background: var(--pink-soft); }
    .pill.active {
      background: var(--rose);
      color: #fff;
      border-color: var(--rose);
      box-shadow: 0 3px 12px rgba(200,80,110,0.22);
    }

    /* ── PRODUCT GRID ────────────────────────────────────── */
    .products-section {
      max-width: 900px;
      margin: 1.5rem auto 6rem;
      padding: 0 1rem;
    }
    .section-heading {
      font-family: 'Cormorant Garamond', serif;
      font-size: 1.5rem;
      font-weight: 400;
      color: var(--text);
      margin-bottom: 1rem;
    }
    .product-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(155px, 1fr));
      gap: 1rem;
    }

    /* ── PRODUCT CARD ────────────────────────────────────── */
    .card {
      background: #fff;
      border-radius: var(--radius);
      overflow: hidden;
      box-shadow: var(--shadow);
      transition: var(--transition);
      display: flex;
      flex-direction: column;
      position: relative;
    }
    .card:hover { transform: translateY(-4px); box-shadow: var(--shadow-lg); }
    .card-img-wrap {
      width: 100%;
      aspect-ratio: 1 / 1;
      overflow: hidden;
      background: var(--pink-soft);
    }
    .card-img-wrap img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      transition: transform 0.4s ease;
    }
    .card:hover .card-img-wrap img { transform: scale(1.06); }
    .card-badge {
      position: absolute;
      top: 8px;
      left: 8px;
      background: var(--rose);
      color: #fff;
      font-size: 0.58rem;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      padding: 2px 7px;
      border-radius: 20px;
    }
    .card-body {
      padding: 0.75rem;
      flex: 1;
      display: flex;
      flex-direction: column;
    }
    .card-name {
      font-family: 'Cormorant Garamond', serif;
      font-size: 1rem;
      font-weight: 600;
      color: var(--text);
      line-height: 1.25;
      margin-bottom: 3px;
    }
    .card-desc {
      font-size: 0.7rem;
      color: var(--text-muted);
      margin-bottom: 0.5rem;
      line-height: 1.4;
    }
    .card-footer {
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin-top: auto;
    }
    .card-price {
      font-family: 'Cormorant Garamond', serif;
      font-size: 1.1rem;
      font-weight: 600;
      color: var(--rose);
    }
    .add-btn {
      background: var(--rose);
      color: #fff;
      border: none;
      border-radius: 50px;
      padding: 0.32rem 0.75rem;
      font-family: 'DM Sans', sans-serif;
      font-size: 0.72rem;
      font-weight: 500;
      cursor: pointer;
      transition: var(--transition);
      display: flex;
      align-items: center;
      gap: 4px;
    }
    .add-btn:hover { background: var(--pink-deep); transform: scale(1.05); }
    .add-btn.added {
      background: #4caf7d;
      pointer-events: none;
    }

    /* ── FLOATING WHATSAPP ───────────────────────────────── */
    .fab-wa {
      position: fixed;
      bottom: 5.5rem;
      right: 1rem;
      background: #25D366;
      color: #fff;
      border-radius: 50px;
      padding: 0.6rem 1rem;
      font-size: 0.78rem;
      font-weight: 500;
      font-family: 'DM Sans', sans-serif;
      text-decoration: none;
      display: flex;
      align-items: center;
      gap: 6px;
      box-shadow: 0 4px 20px rgba(37,211,102,0.35);
      z-index: 90;
      transition: var(--transition);
      animation: floatIn 0.6s 0.5s both;
    }
    .fab-wa:hover { transform: translateY(-3px) scale(1.03); }

    /* ── FLOATING CART ───────────────────────────────────── */
    .fab-cart {
      position: fixed;
      bottom: 1rem;
      right: 1rem;
      background: var(--rose);
      color: #fff;
      border: none;
      border-radius: 50px;
      padding: 0.7rem 1.2rem;
      font-family: 'DM Sans', sans-serif;
      font-size: 0.82rem;
      font-weight: 500;
      cursor: pointer;
      display: flex;
      align-items: center;
      gap: 8px;
      box-shadow: var(--shadow-lg);
      z-index: 90;
      transition: var(--transition);
      animation: floatIn 0.5s 0.3s both;
    }
    .fab-cart:hover { background: var(--pink-deep); transform: translateY(-2px); }
    .fab-badge {
      background: #fff;
      color: var(--rose);
      border-radius: 50%;
      width: 20px;
      height: 20px;
      font-size: 0.7rem;
      font-weight: 700;
      display: flex;
      align-items: center;
      justify-content: center;
    }

    @keyframes floatIn {
      from { opacity: 0; transform: translateY(20px); }
      to   { opacity: 1; transform: translateY(0); }
    }

    /* ── MODAL OVERLAY ───────────────────────────────────── */
    .overlay {
      display: none;
      position: fixed;
      inset: 0;
      background: rgba(42,26,30,0.45);
      z-index: 200;
      backdrop-filter: blur(4px);
      animation: fadeIn 0.25s ease;
    }
    .overlay.open { display: flex; align-items: flex-end; justify-content: center; }
    @media (min-width: 600px) { .overlay.open { align-items: center; } }
    @keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }

    /* ── MODAL PANEL ─────────────────────────────────────── */
    .modal {
      background: #fff;
      width: 100%;
      max-width: 500px;
      border-radius: 24px 24px 0 0;
      max-height: 90vh;
      display: flex;
      flex-direction: column;
      overflow: hidden;
      animation: slideUp 0.35s cubic-bezier(.3,.8,.4,1) both;
    }
    @media (min-width: 600px) {
      .modal { border-radius: 24px; max-height: 80vh; }
    }
    @keyframes slideUp {
      from { transform: translateY(40px); opacity: 0; }
      to   { transform: translateY(0);   opacity: 1; }
    }
    .modal-head {
      padding: 1.2rem 1.4rem;
      border-bottom: 1px solid #fde8ef;
      display: flex;
      align-items: center;
      justify-content: space-between;
      flex-shrink: 0;
    }
    .modal-title {
      font-family: 'Cormorant Garamond', serif;
      font-size: 1.4rem;
      font-weight: 600;
      color: var(--rose);
    }
    .close-btn {
      background: var(--pink-soft);
      border: none;
      color: var(--rose);
      width: 32px;
      height: 32px;
      border-radius: 50%;
      font-size: 1.1rem;
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: center;
      transition: var(--transition);
    }
    .close-btn:hover { background: var(--pink); }
    .modal-body { overflow-y: auto; flex: 1; padding: 1rem 1.4rem; }

    /* ── CART ITEMS ──────────────────────────────────────── */
    .empty-cart {
      text-align: center;
      padding: 2.5rem 1rem;
      color: var(--text-muted);
    }
    .empty-cart .empty-icon { font-size: 2.5rem; margin-bottom: 0.5rem; }
    .empty-cart p { font-size: 0.85rem; }

    .cart-item {
      display: flex;
      align-items: center;
      gap: 0.75rem;
      padding: 0.75rem 0;
      border-bottom: 1px solid #fde8ef;
      animation: fadeIn 0.2s ease;
    }
    .cart-item-img {
      width: 52px;
      height: 52px;
      border-radius: 10px;
      object-fit: cover;
      background: var(--pink-soft);
      flex-shrink: 0;
    }
    .cart-item-info { flex: 1; min-width: 0; }
    .cart-item-name {
      font-family: 'Cormorant Garamond', serif;
      font-size: 0.95rem;
      font-weight: 600;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
      color: var(--text);
    }
    .cart-item-price { font-size: 0.78rem; color: var(--text-muted); }
    .cart-item-subtotal {
      font-size: 0.82rem;
      font-weight: 500;
      color: var(--rose);
      margin-top: 1px;
    }
    .qty-controls {
      display: flex;
      align-items: center;
      gap: 6px;
      flex-shrink: 0;
    }
    .qty-btn {
      width: 26px;
      height: 26px;
      border-radius: 50%;
      border: 1.5px solid var(--pink);
      background: #fff;
      color: var(--rose);
      font-size: 1rem;
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: center;
      line-height: 1;
      transition: var(--transition);
    }
    .qty-btn:hover { background: var(--rose); color: #fff; border-color: var(--rose); }
    .qty-num { font-size: 0.85rem; font-weight: 500; min-width: 16px; text-align: center; }
    .remove-btn {
      background: none;
      border: none;
      color: #ccc;
      cursor: pointer;
      font-size: 1rem;
      padding: 4px;
      transition: color 0.2s;
    }
    .remove-btn:hover { color: #e07090; }

    /* ── CART FOOTER ─────────────────────────────────────── */
    .cart-footer {
      padding: 1rem 1.4rem;
      border-top: 1px solid #fde8ef;
      flex-shrink: 0;
      background: #fff;
    }
    .total-row {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 0.8rem;
    }
    .total-label { font-size: 0.78rem; color: var(--text-muted); letter-spacing: 0.08em; text-transform: uppercase; }
    .total-amount {
      font-family: 'Cormorant Garamond', serif;
      font-size: 1.5rem;
      font-weight: 600;
      color: var(--rose);
    }
    .checkout-btn {
      width: 100%;
      background: linear-gradient(135deg, var(--rose), var(--pink-deep));
      color: #fff;
      border: none;
      border-radius: 14px;
      padding: 0.9rem;
      font-family: 'DM Sans', sans-serif;
      font-size: 0.9rem;
      font-weight: 500;
      cursor: pointer;
      letter-spacing: 0.05em;
      transition: var(--transition);
      box-shadow: 0 4px 16px rgba(200,80,110,0.3);
    }
    .checkout-btn:hover { transform: translateY(-2px); box-shadow: 0 8px 24px rgba(200,80,110,0.35); }

    /* ── ORDER FORM ──────────────────────────────────────── */
    .form-section { margin-top: 0.2rem; }
    .form-section h3 {
      font-family: 'Cormorant Garamond', serif;
      font-size: 1.1rem;
      color: var(--text);
      margin-bottom: 0.8rem;
    }
    .form-group { margin-bottom: 0.8rem; }
    .form-group label {
      display: block;
      font-size: 0.72rem;
      font-weight: 500;
      color: var(--text-muted);
      letter-spacing: 0.08em;
      text-transform: uppercase;
      margin-bottom: 0.3rem;
    }
    .form-group input,
    .form-group textarea {
      width: 100%;
      padding: 0.65rem 0.9rem;
      border: 1.5px solid #f4c8d8;
      border-radius: var(--radius-sm);
      font-family: 'DM Sans', sans-serif;
      font-size: 0.85rem;
      color: var(--text);
      background: var(--cream);
      transition: border-color 0.2s;
      outline: none;
    }
    .form-group input:focus,
    .form-group textarea:focus { border-color: var(--rose); }
    .form-group textarea { resize: vertical; min-height: 70px; }
    .place-order-btn {
      width: 100%;
      background: linear-gradient(135deg, var(--rose), var(--pink-deep));
      color: #fff;
      border: none;
      border-radius: 14px;
      padding: 0.9rem;
      font-family: 'DM Sans', sans-serif;
      font-size: 0.9rem;
      font-weight: 500;
      cursor: pointer;
      margin-top: 0.5rem;
      transition: var(--transition);
      box-shadow: 0 4px 16px rgba(200,80,110,0.3);
    }
    .place-order-btn:hover { transform: translateY(-2px); }
    .place-order-btn:disabled { opacity: 0.6; cursor: not-allowed; transform: none; }
    .back-link {
      display: inline-flex;
      align-items: center;
      gap: 4px;
      font-size: 0.78rem;
      color: var(--text-muted);
      cursor: pointer;
      margin-bottom: 1rem;
      background: none;
      border: none;
      font-family: 'DM Sans', sans-serif;
    }
    .back-link:hover { color: var(--rose); }

    /* ── SUCCESS STATE ───────────────────────────────────── */
    .success-box {
      text-align: center;
      padding: 2rem 1rem;
    }
    .success-icon { font-size: 3rem; margin-bottom: 0.8rem; }
    .success-box h3 {
      font-family: 'Cormorant Garamond', serif;
      font-size: 1.5rem;
      color: var(--rose);
      margin-bottom: 0.5rem;
    }
    .success-box p { font-size: 0.83rem; color: var(--text-muted); line-height: 1.6; }
    .wa-link {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      background: #25D366;
      color: #fff;
      text-decoration: none;
      border-radius: 10px;
      padding: 0.65rem 1.2rem;
      font-size: 0.85rem;
      font-weight: 500;
      margin-top: 1rem;
      transition: var(--transition);
    }
    .wa-link:hover { background: #1da851; }

    /* ── FOOTER ──────────────────────────────────────────── */
    footer {
      background: #2a1a1e;
      color: #c9a8b8;
      text-align: center;
      padding: 2rem 1rem;
      font-size: 0.75rem;
      line-height: 1.8;
    }
    footer strong { color: #f4a9be; }
    footer a { color: #f4a9be; text-decoration: none; }

    /* ── TOAST ───────────────────────────────────────────── */
    .toast {
      position: fixed;
      bottom: 5.5rem;
      left: 50%;
      transform: translateX(-50%) translateY(20px);
      background: #2a1a1e;
      color: #fff;
      padding: 0.6rem 1.2rem;
      border-radius: 30px;
      font-size: 0.8rem;
      z-index: 300;
      opacity: 0;
      transition: all 0.3s ease;
      white-space: nowrap;
      pointer-events: none;
    }
    .toast.show { opacity: 1; transform: translateX(-50%) translateY(0); }

    /* ── UTIL ────────────────────────────────────────────── */
    .hidden { display: none !important; }
    svg { display: block; }
  </style>
</head>
