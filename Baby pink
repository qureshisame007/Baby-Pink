document.getElementById('filterPills').addEventListener('click', e => {
  const btn = e.target.closest('.pill');
  if (!btn) return;
  document.querySelectorAll('.pill').forEach(p => p.classList.remove('active'));
  btn.classList.add('active');
  renderProducts(btn.dataset.cat);
});

/* ════════════════════════════════════════════
   CART HELPERS
════════════════════════════════════════════ */
function saveCart() {
  localStorage.setItem('babyPinkCart', JSON.stringify(cart));
}
function getTotal() {
  return cart.reduce((s, i) => s + i.price * i.qty, 0);
}
function updateBadges() {
  const count = cart.reduce((s, i) => s + i.qty, 0);
  document.getElementById('headerBadge').textContent = count;
  document.getElementById('fabBadge').textContent = count;
}

function addToCart(id, btn) {
  const product = PRODUCTS.find(p => p.id === id);
  const existing = cart.find(c => c.id === id);
  if (existing) {
    existing.qty++;
  } else {
    cart.push({ id: product.id, name: product.name, price: product.price, img: product.img, qty: 1 });
    if (btn) {
      btn.classList.add('added');
      btn.innerHTML = `<svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><path d="M20 6L9 17l-5-5"/></svg> Added`;
    }
  }
  saveCart();
  updateBadges();
  showToast(`${product.name} added to cart 🛒`);
}

function changeQty(id, delta) {
  const item = cart.find(c => c.id === id);
  if (!item) return;
  item.qty += delta;
  if (item.qty <= 0) cart = cart.filter(c => c.id !== id);
  saveCart();
  updateBadges();
  renderCartBody();
  // refresh product grid button states
  renderProducts(document.querySelector('.pill.active').dataset.cat);
}

function removeItem(id) {
  cart = cart.filter(c => c.id !== id);
  saveCart();
  updateBadges();
  renderCartBody();
  renderProducts(document.querySelector('.pill.active').dataset.cat);
}

